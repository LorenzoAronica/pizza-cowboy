    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #FAF7F2;
            --warm: #FBE8DA;
            --gold: #D9A96E;
            --gold-dark: #A87B4B;
            --charcoal: #1A1A1A;
        }
        body { 
            background-color: var(--charcoal); 
            color: var(--cream);
            font-family: 'Cormorant Garamond', serif;
        }
        .gold-gradient {
            background: linear-gradient(to right, var(--gold), var(--gold-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body class="p-8 md:p-20 text-center">
    <header class="mb-16">
        <h1 class="text-6xl md:text-8xl font-bold gold-gradient mb-4">PIZZA COWBOY</h1>
        <p class="text-xl italic text-gray-400">Il Gusto del West, nel cuore della città</p>
    </header>

    <main class="max-w-2xl mx-auto">
        <section class="border-t border-b border-gray-700 py-10 mb-12">
            <h2 class="text-3xl mb-8 tracking-widest text-gold">IL NOSTRO MENU</h2>
            
            <div class="space-y-6">
                <div class="flex justify-between border-b border-gray-800 pb-2">
                    <span class="text-2xl">Margherita del West</span>
                    <span class="text-gold">€8.00</span>
                </div>
                <div class="flex justify-between border-b border-gray-800 pb-2">
                    <span class="text-2xl">Diavola Texana</span>
                    <span class="text-gold">€10.00</span>
                </div>
                <div class="flex justify-between border-b border-gray-800 pb-2">
                    <span class="text-2xl">Pizza Ranch (Bianca)</span>
                    <span class="text-gold">€12.00</span>
                </div>
            </div>
        </section>
        
        <p class="text-gray-500 italic">"Cotta nel forno a legna, amata dai fuorilegge."</p>
    </main>
</body>
</html><!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>La Tua Opinione Conta</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #FAF7F2;
    --warm: #F0E8DA;
    --gold: #C9A96E;
    --gold-dark: #A07840;
    --charcoal: #2C2416;
    --muted: #8A7A65;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background-color: var(--cream);
    color: var(--charcoal);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    background-image: 
      radial-gradient(ellipse at 20% 0%, rgba(201,169,110,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(201,169,110,0.08) 0%, transparent 55%);
  }

  .card {
    background: #fff;
    border-radius: 24px;
    max-width: 420px;
    width: 100%;
    padding: 40px 32px;
    box-shadow: 0 2px 6px rgba(44,36,22,0.06), 0 20px 60px rgba(44,36,22,0.08);
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold-dark), var(--gold), var(--gold-dark));
  }

  .logo-ring {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--warm), var(--cream));
    border: 2px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px;
    color: var(--gold-dark);
    font-weight: 600;
    letter-spacing: -1px;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: var(--charcoal);
    letter-spacing: 0.5px;
    line-height: 1.3;
  }

  .subtitle {
    font-size: 14px;
    color: var(--muted);
    margin-top: 8px;
    line-height: 1.5;
    font-weight: 300;
  }

  /* STARS */
  .stars-row {
    display: flex;
    gap: 10px;
    justify-content: center;
    padding: 8px 0;
  }

  .star-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 12px;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1);
    position: relative;
  }

  .star-btn:hover { transform: scale(1.25) translateY(-3px); }
  .star-btn:active { transform: scale(0.95); }

  .star-btn svg {
    width: 42px; height: 42px;
    transition: fill 0.25s ease, filter 0.25s ease;
    filter: drop-shadow(0 0 0px var(--gold));
  }

  .star-btn.filled svg {
    fill: var(--gold);
    filter: drop-shadow(0 2px 8px rgba(201,169,110,0.5));
  }

  .star-btn:not(.filled) svg { fill: #E5DDD0; }

  /* SECTIONS */
  .section {
    display: none;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  .section.visible {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  /* BUTTONS */
  .btn-google {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px;
    background: var(--charcoal);
    color: white;
    border: none;
    border-radius: 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.2px;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), background 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }
  .btn-google:hover {
    background: #1a1008;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(44,36,22,0.25);
  }
  .btn-google:active { transform: scale(0.98); }

  .btn-ai {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px;
    background: transparent;
    color: var(--gold-dark);
    border: 1.5px solid var(--gold);
    border-radius: 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), background 0.2s ease;
  }
  .btn-ai:hover {
    background: var(--warm);
    transform: translateY(-2px);
  }
  .btn-ai:active { transform: scale(0.98); }

  .btn-send {
    width: 100%;
    padding: 16px;
    background: linear-gradient(135deg, var(--gold-dark), var(--gold));
    color: white;
    border: none;
    border-radius: 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.2px;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s ease;
  }
  .btn-send:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(160,120,64,0.4);
  }
  .btn-send:active { transform: scale(0.98); }

  /* AI BOX */
  .ai-box {
    background: var(--warm);
    border-radius: 14px;
    padding: 20px;
    font-size: 14px;
    color: var(--charcoal);
    line-height: 1.65;
    border-left: 3px solid var(--gold);
    display: none;
    animation: slideIn 0.4s ease forwards;
    font-style: italic;
    position: relative;
  }

  .ai-box .ai-label {
    font-style: normal;
    font-size: 11px;
    font-weight: 500;
    color: var(--gold-dark);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-loading {
    display: flex;
    gap: 5px;
    justify-content: center;
    padding: 16px 0 8px;
  }
  .dot {
    width: 7px; height: 7px;
    background: var(--gold);
    border-radius: 50%;
    animation: bounce 1.2s infinite;
  }
  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
    40% { transform: translateY(-6px); opacity: 1; }
  }

  /* FEEDBACK FORM */
  .feedback-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
    display: block;
  }

  textarea {
    width: 100%;
    background: var(--warm);
    border: 1.5px solid transparent;
    border-radius: 12px;
    padding: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--charcoal);
    resize: none;
    height: 110px;
    line-height: 1.6;
    transition: border-color 0.2s ease;
    outline: none;
  }
  textarea:focus { border-color: var(--gold); }
  textarea::placeholder { color: var(--muted); }

  /* DIVIDER */
  .divider {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
    font-size: 12px;
    letter-spacing: 0.5px;
  }
  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--warm);
  }

  /* SUCCESS */
  .success-msg {
    display: none;
    text-align: center;
    padding: 20px;
    animation: slideIn 0.4s ease forwards;
  }
  .success-icon {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, var(--gold-dark), var(--gold));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 14px;
    font-size: 22px;
  }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 24px; left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--charcoal);
    color: white;
    padding: 12px 22px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 400;
    transition: transform 0.4s cubic-bezier(.34,1.56,.64,1), opacity 0.3s ease;
    opacity: 0;
    white-space: nowrap;
    pointer-events: none;
    z-index: 9999;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--warm);
    border: 1px solid var(--gold);
    border-radius: 100px;
    padding: 4px 12px;
    font-size: 11px;
    color: var(--gold-dark);
    font-weight: 500;
    letter-spacing: 0.5px;
    margin-bottom: 20px;
  }

  .pulse {
    width: 7px; height: 7px;
    background: var(--gold);
    border-radius: 50%;
    animation: pulse-anim 1.8s infinite;
  }
  @keyframes pulse-anim {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }
</style>
</head>
<body>

<div class="card">

  <!-- HEADER -->
  <div class="text-center mb-6">
    <div class="logo-ring">TR</div>
    <div class="badge">
      <span class="pulse"></span>
      Feedback riservato
    </div>
    <h1>Come è stata<br>la tua esperienza?</h1>
    <p class="subtitle">La tua opinione ci aiuta a migliorare ogni giorno. Ci vogliono solo 20 secondi.</p>
  </div>

  <!-- DIVIDER STELLE -->
  <div class="divider mb-4">Valuta</div>

  <!-- STAR RATING -->
  <div class="stars-row mb-2" id="starsRow" role="group" aria-label="Valutazione da 1 a 5 stelle">
    <!-- generati da JS -->
  </div>

  <p class="text-center text-xs mb-6" style="color:var(--muted); height:18px;" id="starLabel"></p>

  <!-- SEZIONE ALTA (4-5 stelle) -->
  <div class="section" id="sectionPositive">
    <div class="space-y-3">
      <button class="btn-google" id="btnGoogle" onclick="openGoogleReview()">
        <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#EA4335" d="M5.27 9.76A7.08 7.08 0 0 1 19 10.5h-7v3h4a4.07 4.07 0 0 1-1.67 2.45l2.67 2.07A7 7 0 0 0 19 10.5a7.16 7.16 0 0 0-.12-1.38"/><path fill="#34A853" d="m5.27 14.24 2.66-2.07a4.08 4.08 0 0 1 0-4.33L5.27 5.77A7 7 0 0 0 5 12a7 7 0 0 0 .27 2.24"/><path fill="#4A90D9" d="M12 5c1.74 0 3.29.6 4.52 1.78L19 4.27A7 7 0 0 0 12 2a7 7 0 0 0-6.73 3.77l2.66 2.07A4.08 4.08 0 0 1 12 5"/><path fill="#FBBC05" d="M12 19a4.08 4.08 0 0 1-4.07-3.83l-2.66 2.06A7 7 0 0 0 12 22a7 7 0 0 0 6.69-4.45l-2.67-2.07A4.07 4.07 0 0 1 12 19"/></svg>
        Lascia una recensione su Google
      </button>

      <div class="divider">oppure</div>

      <button class="btn-ai" id="btnGenerateAI" onclick="generateAIReview()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        Genera testo con AI
      </button>

      <!-- AI LOADING / BOX -->
      <div id="aiLoading" style="display:none;">
        <div class="ai-loading">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
        </div>
        <p class="text-center text-xs" style="color:var(--muted);">L'AI sta scrivendo per te…</p>
      </div>

      <div class="ai-box" id="aiBox">
        <div class="ai-label">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Suggerimento AI &nbsp;<span id="aiStyleBadge" style="font-style:normal; font-size:10px; background:rgba(201,169,110,0.18); border-radius:100px; padding:2px 8px; letter-spacing:0.5px;"></span>
        </div>
        <span id="aiText"></span>
        <div style="margin-top:14px; display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
          <button onclick="copyAIText()" id="btnCopy" style="display:flex; align-items:center; gap:6px; background:none; border:none; color:var(--gold-dark); font-size:12px; font-weight:500; cursor:pointer; font-family:'DM Sans',sans-serif; letter-spacing:0.3px; padding:0; transition:opacity 0.2s;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Copia il testo
          </button>
          <button onclick="generateAIReview(true)" style="display:flex; align-items:center; gap:6px; background:none; border:none; color:var(--muted); font-size:12px; font-weight:400; cursor:pointer; font-family:'DM Sans',sans-serif; letter-spacing:0.3px; padding:0; transition:color 0.2s;" onmouseover="this.style.color='var(--charcoal)'" onmouseout="this.style.color='var(--muted)'">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            Rigenera suggerimento
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- SEZIONE BASSA (1-3 stelle) -->
  <div class="section" id="sectionNegative">
    <p class="text-sm mb-4" style="color:var(--muted); line-height:1.6;">
      Ci dispiace. Il tuo feedback è prezioso e verrà letto personalmente dal responsabile.
    </p>
    <label class="feedback-label" for="feedbackText">Descrivi cosa non ha funzionato</label>
    <textarea id="feedbackText" placeholder="Raccontaci cosa è successo e come possiamo migliorare…"></textarea>
    <div class="mt-3">
      <button class="btn-send" onclick="sendFeedback()">Invia al manager →</button>
    </div>
    <div class="success-msg" id="successMsg">
      <div class="success-icon">✓</div>
      <p style="font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:300; color:var(--charcoal);">Grazie per la sincerità</p>
      <p class="text-sm mt-2" style="color:var(--muted);">Il responsabile ti risponderà al più presto.</p>
    </div>
  </div>

</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  // ---- CONFIG ----
  const GOOGLE_REVIEW_URL = "https://www.google.com/search?sca_esv=33d040cb389eca3f&rlz=1C5CHFA_enIT1035IT1035&sxsrf=ANbL-n55_pQCyUvfVOiZsFnv9_pcptuCWQ:1777057410878&si=AL3DRZHrmvnFAVQPOO2Bzhf8AX9KZZ6raUI_dT7DG_z0kV2_x7Th1pkHsQnrdeWziGMMBT4j_DKPd3t6kZYt5LG-2oSA35-46m9J2ZJMafSD3dhXPRHWJ-TaTLNxkgPMNGXepbRFj4uM5KoWcenmn5x-uza2ZIZEaw%3D%3D&q=Ristorante+%22Pizza+Cowboy%22+Recensioni&sa=X&ved=2ahUKEwi-8-HdloeUAxWo3gIHHRqONSkQ0bkNegQIQBAH&biw=1424&bih=663&dpr=2";

  // ---- DATA ----
  const labels = ['Pessima', 'Scarsa', 'Nella media', 'Ottima', 'Eccellente'];
  // Stili tematici — ogni stile ha più varianti per evitare ripetizioni
  const reviewStyles = [
    {
      tema: 'cibo',
      icona: '🍕',
      varianti: [
        "Pizza incredibile, ingredienti freschissimi e impasto leggero e digeribile. Si sente la qualità in ogni morso. Consigliatissimo!",
        "Impasto perfetto, croccante fuori e morbido dentro. Gli ingredienti sono di prima scelta, si sente che non fanno compromessi. Da provare assolutamente.",
        "La pizza migliore che abbia mangiato a Roma da tanto tempo. Fresca, saporita, con quel equilibrio tra condimento e impasto che è difficile trovare. Tornerò sicuramente!"
      ]
    },
    {
      tema: 'servizio',
      icona: '🤝',
      varianti: [
        "Personale super gentile e attento, ci hanno fatto sentire ospiti speciali dalla prima all'ultima portata. Professionalità vera.",
        "Servizio rapido ed efficiente anche con il locale pieno. I ragazzi sono sempre disponibili con il sorriso. Un dettaglio che fa la differenza.",
        "Accolti benissimo sin dall'ingresso. Il personale conosce il menu alla perfezione e sa consigliare senza pressare. Raro trovare questo livello di cura."
      ]
    },
    {
      tema: 'atmosfera',
      icona: '✨',
      varianti: [
        "Il miglior posto in zona per una cena tra amici. Atmosfera accogliente, musica giusta, e non si sente mai la confusione. Ci torneremo presto.",
        "Un locale con carattere, caldo e autentico. Si respira passione in ogni angolo. Il tipo di posto che metti subito nei preferiti.",
        "Ambiente curato nei dettagli, illuminazione perfetta, non troppo rumoroso. Ideale sia per una serata romantica che per una cena in gruppo. Sempre una bella esperienza."
      ]
    },
    {
      tema: 'breve',
      icona: '⭐',
      varianti: [
        "Pizza top, servizio veloce, prezzi onesti. Cosa chiedere di più? Ci vediamo presto!",
        "Esperienza 5 stelle senza dubbi. Buono, veloce, simpatico. Uno di quei posti dove torni sempre volentieri.",
        "Ottimo sotto tutti i punti di vista. Lo consiglio a chiunque cerchi qualità vera senza spendere una fortuna."
      ]
    }
  ];

  let lastStyleIndex = -1;

  let currentRating = 0;

  // ---- ANALYTICS ----
  function trackEvent(event, data = {}) {
    const payload = { event, timestamp: new Date().toISOString(), ...data };
    console.log('[Analytics]', payload);
    // In produzione: fetch('/api/analytics', { method:'POST', body: JSON.stringify(payload) });
  }

  // ---- RENDER STARS ----
  function renderStars() {
    const row = document.getElementById('starsRow');
    row.innerHTML = '';
    for (let i = 1; i <= 5; i++) {
      const btn = document.createElement('button');
      btn.className = 'star-btn' + (i <= currentRating ? ' filled' : '');
      btn.setAttribute('aria-label', `${i} stelle`);
      btn.innerHTML = `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
      btn.addEventListener('click', () => selectRating(i));
      btn.addEventListener('mouseenter', () => hoverStars(i));
      btn.addEventListener('mouseleave', () => hoverStars(currentRating));
      row.appendChild(btn);
    }
  }

  function hoverStars(n) {
    document.querySelectorAll('.star-btn').forEach((btn, i) => {
      btn.classList.toggle('filled', i < n);
    });
    document.getElementById('starLabel').textContent = n ? labels[n - 1] : '';
  }

  function selectRating(n) {
    currentRating = n;
    renderStars();
    document.getElementById('starLabel').textContent = labels[n - 1];

    // ANALYTICS
    trackEvent('star_clicked', { rating: n, category: n >= 4 ? 'positive' : 'negative' });

    // Reset AI box
    document.getElementById('aiBox').style.display = 'none';
    document.getElementById('aiLoading').style.display = 'none';

    // Mostra sezione
    showSection(n >= 4 ? 'sectionPositive' : 'sectionNegative');
  }

  function showSection(id) {
    ['sectionPositive', 'sectionNegative'].forEach(s => {
      const el = document.getElementById(s);
      el.classList.remove('visible');
      el.style.display = 'none';
    });
    const target = document.getElementById(id);
    target.style.display = 'block';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => target.classList.add('visible'));
    });
    target.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ---- GOOGLE REVIEW ----
  function openGoogleReview() {
    trackEvent('google_review_clicked', { rating: currentRating });
    showToast('Grazie mille! Ci vediamo su Google ⭐');
    setTimeout(() => window.open(GOOGLE_REVIEW_URL, '_blank'), 400);
  }

  // ---- AI REVIEW ----
  function pickRandomStyle() {
    let idx;
    do { idx = Math.floor(Math.random() * reviewStyles.length); }
    while (idx === lastStyleIndex && reviewStyles.length > 1);
    lastStyleIndex = idx;
    return reviewStyles[idx];
  }

  function generateAIReview(isRegen = false) {
    const loading = document.getElementById('aiLoading');
    const box = document.getElementById('aiBox');
    box.style.display = 'none';
    loading.style.display = 'block';

    trackEvent(isRegen ? 'ai_regenerate_clicked' : 'ai_generate_clicked', { rating: currentRating });

    setTimeout(() => {
      loading.style.display = 'none';
      const style = pickRandomStyle();
      const text = style.varianti[Math.floor(Math.random() * style.varianti.length)];
      document.getElementById('aiStyleBadge').textContent = style.icona + ' ' + style.tema.charAt(0).toUpperCase() + style.tema.slice(1);
      document.getElementById('aiText').textContent = text;
      box.style.display = 'block';
    }, isRegen ? 900 : 1800);
  }

  function copyAIText() {
    const text = document.getElementById('aiText').textContent;
    const btn = document.getElementById('btnCopy');
    navigator.clipboard.writeText(text).then(() => {
      showToast('Testo copiato negli appunti ✓');
      btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Copiato!`;
      btn.style.color = 'var(--gold-dark)';
      setTimeout(() => {
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copia il testo`;
      }, 2000);
    });
    trackEvent('ai_text_copied', { tema: reviewStyles[lastStyleIndex]?.tema });
  }

  // ---- FEEDBACK ----
  function sendFeedback() {
    const text = document.getElementById('feedbackText').value.trim();
    if (!text) { showToast('Scrivi un messaggio prima di inviare'); return; }

    trackEvent('private_feedback_sent', { rating: currentRating, length: text.length });

    document.getElementById('feedbackText').style.display = 'none';
    document.querySelector('.btn-send').style.display = 'none';
    const success = document.getElementById('successMsg');
    success.style.display = 'block';
  }

  // ---- TOAST ----
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2800);
  }

  // ---- INIT ----
  renderStars();
</script>
</body>
</html>
